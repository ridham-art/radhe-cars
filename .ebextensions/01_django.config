option_settings:
  aws:elasticbeanstalk:environment:proxy:
    ProxyServer: nginx
  aws:elasticbeanstalk:application:environment:
    DJANGO_SETTINGS_MODULE: radhe_cars.settings
    # Avoid empty $PORT in Procfile; AL2023 hook can fail if gunicorn bind is wrong
    PORT: '8000'

# migrate is NOT run here — run manually after first good deploy: python manage.py migrate
# collectstatic disabled until first deploy succeeds; then run on server: python manage.py collectstatic --noinput
# container_commands:
#   01_collectstatic:
#     command: "python manage.py collectstatic --noinput"
#     leader_only: true
