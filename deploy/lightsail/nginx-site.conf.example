# Copy to /etc/nginx/sites-available/radhe-cars (then symlink to sites-enabled).
# Replace server_name and ssl_certificate paths after certbot.
# Upstream must match gunicorn --bind in gunicorn.service.
#
# Cache-Control:
# - /static/ : long cache + immutable (safe with Django ManifestStaticFilesStorage — filenames are hashed).
# - /media/  : user uploads may change at the same URL; use shorter TTL unless you version filenames.

upstream radhe_cars_app {
    server 127.0.0.1:8000;
}

server {
    listen 80;
    server_name your-lightsail-domain.com www.your-lightsail-domain.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name your-lightsail-domain.com www.your-lightsail-domain.com;

    ssl_certificate /etc/letsencrypt/live/your-lightsail-domain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/your-lightsail-domain.com/privkey.pem;

    client_max_body_size 25M;

    # Django collectstatic output (hashed filenames — cache 1 year)
    location /static/ {
        alias /var/www/radhe-cars/staticfiles/;
        access_log off;
        expires 365d;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # User uploads: same URL can be replaced — avoid "immutable"; tune max-age as needed
    location /media/ {
        alias /var/www/radhe-cars/media/;
        expires 7d;
        add_header Cache-Control "public, max-age=604800";
    }

    location / {
        proxy_pass http://radhe_cars_app;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # HTML should not be cached long at the edge (dynamic pages)
        add_header Cache-Control "no-cache" always;
    }
}
