# Copy to .env (never commit .env). Generate SECRET_KEY:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

SECRET_KEY=

# Production: DEBUG=False or omit. Local: DEBUG=True
DEBUG=False

# Optional: log server-side duration for /admin-panel/ (console: radhe_cars.admin_panel_timing)
# ADMIN_PANEL_TIMING_LOG=1

# Comma-separated hosts (default: radheauto.com,www.radheauto.com)
# ALLOWED_HOSTS=radheauto.com,www.radheauto.com

# --- Supabase (recommended): one URL, no DB_* vars needed ---
# Dashboard → Project Settings → Database → Connection string → URI
# Use "Session mode" / pooler host (*.pooler.supabase.com) if direct IPv6 fails.
# Replace [YOUR-PASSWORD] and URL-encode special chars in password (@ → %40).
# Example shape:
# DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# SSL: keep default (required for Supabase remote)
# DATABASE_SSL_REQUIRE=true

# --- OR local Postgres only (leave DATABASE_URL empty) ---
# DB_HOST=localhost
# DB_NAME=radhe_auto
# DB_USER=postgres
# DB_PASSWORD=
# DB_PORT=5432

# Google OAuth (required by settings)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Extra CSRF origins (comma-separated), merged with https://radheauto.com and https://www.radheauto.com
# CSRF_TRUSTED_ORIGINS=

# Behind Nginx on HTTPS (default true when DEBUG=False)
# USE_X_FORWARDED_HEADERS=true

# Optional: disable automatic HTTP→HTTPS redirect in Django if Nginx handles it (default true when DEBUG=False)
# SECURE_SSL_REDIRECT=true

# Manual steps after deploy:
# 1) Admin → Sites → change domain to www.radheauto.com (or your canonical host).
# 2) Google Cloud Console → OAuth → Authorized redirect URIs:
#    https://radheauto.com/accounts/google/login/callback/
#    https://www.radheauto.com/accounts/google/login/callback/
# 3) Nginx: location /media/ → alias to MEDIA_ROOT; SSL via Certbot.
