# Django — required (no defaults in code; app will not start without these)
# Generate SECRET_KEY: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=
# Must be exactly True or False string for DEBUG (e.g. DEBUG=True for local dev)
DEBUG=True
# ALLOWED_HOSTS is temporarily ['*'] in settings.py; set your domain list there before final go-live
# HTTPS behind nginx on Lightsail — set when terminating TLS at the proxy
# USE_X_FORWARDED_HEADERS=true
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Database (PostgreSQL)
# Render: set DATABASE_URL (Supabase URI). Encode @ in password as %40.
# Render is IPv4: use Supabase "Session pooler" URI (not Direct), host *.pooler.supabase.com
# Pooler URLs auto-use CONN_MAX_AGE=0 and disable server-side cursors (PgBouncer-safe).
# Render Build Command should be only: pip install -r requirements.txt && python manage.py collectstatic --noinput
# (Do not run migrate during build — run it once in Render Shell after deploy if needed.)
DB_NAME=radhe_auto
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# Production: set DATABASE_URL in the host (Render/EB), not in git. Encode @ in password as %40.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Google OAuth — required (no defaults in code)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
