# Django
# Production: SECRET_KEY must be 50+ chars with 5+ unique chars (never use django-insecure- prefix).
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-change-in-production
# Local dev: DEBUG=True (weak SECRET_KEY is OK). Production: DEBUG=False + strong SECRET_KEY + ALLOWED_HOSTS.
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Production example: DEBUG=False, ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# HTTPS behind a reverse proxy (nginx, ALB, etc.) — set so Django trusts X-Forwarded-Proto
# USE_X_FORWARDED_HEADERS=true
# Optional overrides (defaults are production-safe when DEBUG=False)
# SECURE_SSL_REDIRECT=true
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_PRELOAD=true
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Database (PostgreSQL)
# Render: set DATABASE_URL (Supabase URI). Encode @ in password as %40.
# Render is IPv4: use Supabase "Session pooler" URI (not Direct), host *.pooler.supabase.com
# Pooler URLs auto-use CONN_MAX_AGE=0 and disable server-side cursors (PgBouncer-safe).
# Render Build Command should be only: pip install -r requirements.txt && python manage.py collectstatic --noinput
# (Do not run migrate during build — run it once in Render Shell after deploy if needed.)
DB_NAME=radhe_auto
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

DATABASE_URL = "postgresql://postgres.rloqgpedgapahicxageo:Radhe-auto%40pass3781@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
